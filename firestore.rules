rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function signedInEmailLower() {
      return request.auth.token.email.lower();
    }

    function hasInviteForSignedInEmail() {
      return isSignedIn()
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/adminInvites/$(signedInEmailLower()));
    }

    function inviteMatchesSignedInEmail(emailKey) {
      return isSignedIn()
        && request.auth.token.email != null
        && signedInEmailLower() == emailKey;
    }

    function isBootstrapAdminEmail() {
      return isSignedIn()
        && request.auth.token.email != null
        && signedInEmailLower() == 'joncheng5@gmail.com';
    }

    function isBootstrapLegacyOwnerUid(ownerUid) {
      return isBootstrapAdminEmail()
        && [ownerUid].hasAny(['aXjhgOzT0mPQt97bGMqR4CHI1jp1']);
    }

    function hasRotationDoc(rotationCode) {
      return exists(/databases/$(database)/documents/rotations/$(rotationCode));
    }

    function rotationData(rotationCode) {
      return get(/databases/$(database)/documents/rotations/$(rotationCode)).data;
    }

    function rotationLooksLegacy(data) {
      return !data.keys().hasAny(['ownerUid']) && !data.keys().hasAny(['adminUids']);
    }

    function rotationAllowsAdmin(data) {
      return isAdmin()
        && (
          isBootstrapAdminEmail()
          || (data.keys().hasAny(['ownerUid']) && data.ownerUid == request.auth.uid)
          || (data.keys().hasAny(['ownerUid']) && isBootstrapLegacyOwnerUid(data.ownerUid))
          || (request.auth.token.email != null && data.keys().hasAny(['ownerEmail']) && data.ownerEmail.lower() == signedInEmailLower())
          || (data.keys().hasAny(['adminUids']) && data.adminUids is list && data.adminUids.hasAny([request.auth.uid]))
          || rotationLooksLegacy(data)
        );
    }

    function isRotationAdmin(rotationCode) {
      return hasRotationDoc(rotationCode) && rotationAllowsAdmin(rotationData(rotationCode));
    }

    // Ownership (transferring the rotation, editing the admin roster) is a strict
    // subset of admin: it deliberately OMITS the adminUids-membership clause so a
    // co-admin who was merely added to adminUids cannot rewrite ownerUid/adminUids
    // to seize the rotation or lock out the owner. Only the owner (by uid or
    // ownerEmail), the bootstrap admin, or a legacy/unclaimed doc qualifies.
    function rotationAllowsOwner(data) {
      return isAdmin()
        && (
          isBootstrapAdminEmail()
          || (data.keys().hasAny(['ownerUid']) && data.ownerUid == request.auth.uid)
          || (data.keys().hasAny(['ownerUid']) && isBootstrapLegacyOwnerUid(data.ownerUid))
          || (request.auth.token.email != null && data.keys().hasAny(['ownerEmail']) && data.ownerEmail.lower() == signedInEmailLower())
          || rotationLooksLegacy(data)
        );
    }

    function isRotationOwner(rotationCode) {
      return hasRotationDoc(rotationCode) && rotationAllowsOwner(rotationData(rotationCode));
    }

    function isRotationStudent(rotationCode) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/rotations/$(rotationCode)/students/$(request.auth.uid));
    }

    function canReadRotation(rotationCode) {
      return isRotationAdmin(rotationCode) || isRotationStudent(rotationCode);
    }

    function isStudentOwner(studentId) {
      return isSignedIn() && request.auth.uid == studentId;
    }

    function hasValidStudentName() {
      return request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 50;
    }

    function hasNoLegacyStudentLoginPin() {
      return !request.resource.data.keys().hasAny(['loginPin']);
    }

    function hasValidTeamSnapshot(studentId) {
      // Upper bounds are generous sanity ceilings (a full rotation tops out
      // around ~400 pts / a few dozen patients) — they exist so a student
      // can't write points: 999999 and vandalize the shared leaderboard.
      return request.resource.data.studentId == studentId
        && hasValidStudentName()
        && request.resource.data.points is int
        && request.resource.data.points >= 0
        && request.resource.data.points <= 10000
        && request.resource.data.patientCount is int
        && request.resource.data.patientCount >= 0
        && request.resource.data.patientCount <= 500
        && request.resource.data.activePatientCount is int
        && request.resource.data.activePatientCount >= 0
        && request.resource.data.activePatientCount <= 500
        && request.resource.data.dischargedPatientCount is int
        && request.resource.data.dischargedPatientCount >= 0
        && request.resource.data.dischargedPatientCount <= 500
        && request.resource.data.levelName is string
        && request.resource.data.levelName.size() > 0
        && request.resource.data.levelIcon is string
        && request.resource.data.levelIcon.size() > 0
        && request.resource.data.topicCounts is map
        && request.resource.data.updatedAt is string;
    }

    // Student-submitted "this page confused me" feedback. Create-only for
    // students (no update — a submission is a point-in-time signal, not an
    // editable record); admins get/list/delete to triage.
    function hasValidStudentFeedback(studentId) {
      return request.resource.data.studentId == studentId
        && request.resource.data.keys().hasOnly(['studentId', 'name', 'page', 'tag', 'note', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 50
        && request.resource.data.page is string
        && request.resource.data.page.size() > 0
        && request.resource.data.page.size() <= 100
        && request.resource.data.tag in ['Confusing', 'Broken', 'Idea', 'Love it']
        && request.resource.data.createdAt is string
        && request.resource.data.createdAt.size() <= 40
        && (!request.resource.data.keys().hasAny(['note']) || (
          request.resource.data.note is string
          && request.resource.data.note.size() <= 500
        ));
    }

    match /admins/{uid} {
      allow get: if isSignedIn() && request.auth.uid == uid;
      allow list: if false;
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.auth.token.email != null
        && request.resource.data.email.lower() == signedInEmailLower()
        && (hasInviteForSignedInEmail() || isBootstrapAdminEmail());
      allow update, delete: if false;
    }

    match /adminInvites/{emailKey} {
      // Invitees can read their own invite to claim it; otherwise only the
      // master (bootstrap) admin sees the invite list and creates/edits invites.
      allow get: if isBootstrapAdminEmail() || inviteMatchesSignedInEmail(emailKey);
      allow list: if isBootstrapAdminEmail();
      allow create: if isBootstrapAdminEmail()
        && request.resource.data.email == emailKey
        && request.resource.data.createdByUid == request.auth.uid;
      allow update: if (
        isBootstrapAdminEmail()
        && request.resource.data.email == resource.data.email
      ) || (
        inviteMatchesSignedInEmail(emailKey)
        && request.resource.data.email == resource.data.email
        && request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['claimedAt', 'claimedByUid', 'claimedByEmail', 'status'])
        && request.resource.data.claimedByUid == request.auth.uid
        && request.resource.data.claimedByEmail.lower() == signedInEmailLower()
      );
      allow delete: if isBootstrapAdminEmail();
    }

    match /rotationCodes/{rotationCode} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isAdmin()
        && request.resource.data.rotationCode == rotationCode
        && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isRotationAdmin(rotationCode);
    }

    match /studentAssignments/{studentId} {
      // Assignment docs carry the student's email — readable by the student,
      // the master admin, or an admin of the rotation the student is in
      // (not every admin of any rotation).
      allow get: if isStudentOwner(studentId)
        || isBootstrapAdminEmail()
        || (isAdmin() && isRotationAdmin(resource.data.activeRotationCode));
      allow list: if false;
      allow create, update: if isStudentOwner(studentId)
        && request.resource.data.studentId == studentId
        && request.resource.data.activeRotationCode is string
        && request.resource.data.activeRotationCode.size() >= 4
        && request.resource.data.activeRotationCode.size() <= 20
        && request.resource.data.rotationCodes is list
        && request.resource.data.rotationCodes.size() > 0
        && request.resource.data.updatedAt is string
        && (!request.resource.data.keys().hasAny(['email']) || request.resource.data.email is string);
      allow delete: if isStudentOwner(studentId)
        || isBootstrapAdminEmail()
        || (isAdmin() && isRotationAdmin(resource.data.activeRotationCode));
    }

    // ─── Rotation documents ────────────────────────────────────────
    match /rotations/{rotationCode} {
      allow get: if canReadRotation(rotationCode);
      // List uses only PROVABLE clauses (Firestore validates queries statically,
      // not per-document): the bootstrap check is request-only, and the two
      // resource clauses match the client's exact query shapes
      // (array-contains on adminUids / equality on ownerUid). Email matching
      // needs .lower() on resource data, which the prover can't handle — that
      // path lives in `get` via rotationAllowsAdmin instead.
      allow list: if isAdmin() && (
        isBootstrapAdminEmail()
        || request.auth.uid in resource.data.adminUids
        || resource.data.ownerUid == request.auth.uid
      );

      allow create: if isAdmin()
                    && request.resource.data.keys().hasAll(['name', 'createdAt', 'ownerUid', 'ownerEmail', 'adminUids'])
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.adminUids is list
                    && request.resource.data.adminUids.hasAny([request.auth.uid]);

      // Any rotation admin may edit content/metadata, but ONLY the owner may
      // change ownership fields (ownerUid / ownerEmail / adminUids).
      allow update: if (
                      isRotationAdmin(rotationCode)
                      && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['curriculum', 'articles', 'announcements', 'settings',
                                   'clinicGuides', 'name', 'location', 'dates',
                                   'archived', 'archivedAt'])
                    ) || (
                      isRotationOwner(rotationCode)
                      && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['curriculum', 'articles', 'announcements', 'settings',
                                   'clinicGuides', 'name', 'location', 'dates',
                                   'archived', 'archivedAt', 'ownerUid', 'ownerEmail', 'adminUids'])
                    );

      allow delete: if isRotationAdmin(rotationCode);

      // ─── Student subcollection ─────────────────────────────────
      // Create/update additionally require the student NOT be tombstoned:
      // an admin delete writes the tombstone first, so a device that was
      // offline during the delete gets permission-denied when its queue
      // later flushes, instead of silently resurrecting the deleted doc.
      match /students/{studentId} {
        allow get: if isRotationAdmin(rotationCode) || isStudentOwner(studentId);
        allow list: if isRotationAdmin(rotationCode);
        allow create: if (isRotationAdmin(rotationCode) || isStudentOwner(studentId))
                      && exists(/databases/$(database)/documents/rotationCodes/$(rotationCode))
                      && !exists(/databases/$(database)/documents/rotations/$(rotationCode)/studentTombstones/$(studentId))
                      && request.resource.data.keys().hasAll(['name'])
                      && hasValidStudentName()
                      && hasNoLegacyStudentLoginPin();
        allow update: if (isRotationAdmin(rotationCode) || isStudentOwner(studentId))
                      && !exists(/databases/$(database)/documents/rotations/$(rotationCode)/studentTombstones/$(studentId))
                      && hasValidStudentName()
                      && hasNoLegacyStudentLoginPin();
        allow delete: if isRotationAdmin(rotationCode);
      }

      match /team/{studentId} {
        allow get, list: if isRotationAdmin(rotationCode) || isRotationStudent(rotationCode);
        allow create, update: if (isRotationAdmin(rotationCode) || isStudentOwner(studentId))
                              && exists(/databases/$(database)/documents/rotationCodes/$(rotationCode))
                              && !exists(/databases/$(database)/documents/rotations/$(rotationCode)/studentTombstones/$(studentId))
                              && hasValidTeamSnapshot(studentId);
        allow delete: if isRotationAdmin(rotationCode) || isStudentOwner(studentId);
      }

      // ─── Deletion tombstones ───────────────────────────────────
      // Written by admin deletes BEFORE the student/team docs are removed, so
      // there is no gap in which a concurrent write recreates the doc. Only
      // admin paths may create or clear them — a removed student must not be
      // able to un-remove themselves by rejoining.
      match /studentTombstones/{studentId} {
        allow get: if isRotationAdmin(rotationCode) || isStudentOwner(studentId);
        // deleteRotation enumerates this subcollection client-side.
        allow list: if isRotationAdmin(rotationCode);
        allow create, delete: if isRotationAdmin(rotationCode);
        allow update: if false;
      }

      // ─── Student feedback subcollection ───────────────────────────
      // One-tap "this page confused me" reports. Students can only create
      // their own entries and can never read them back (avoids one student
      // seeing another's feedback); only a rotation admin can triage.
      match /feedback/{entryId} {
        allow get, list: if isRotationAdmin(rotationCode);
        allow create: if isRotationStudent(rotationCode)
                      && request.resource.data.studentId == request.auth.uid
                      && hasValidStudentFeedback(request.auth.uid);
        allow update: if false;
        allow delete: if isRotationAdmin(rotationCode);
      }
    }

    // ─── Trigger Email extension outbox (WS-4) ─────────────────────
    // Written ONLY by the onAdminInviteCreated Cloud Function via the Admin SDK
    // (which bypasses these rules). No client ever reads or writes `mail`:
    // clients must not be able to enqueue arbitrary outbound email.
    match /mail/{docId} {
      allow read, write: if false;
    }

    // ─── App-wide feature flags (WS-3) ─────────────────────────────
    // Flat boolean map read by every signed-in client at boot (stale-while-
    // revalidate in src/utils/flags.ts); write access is bootstrap-admin-only
    // for now (org-owner write access is a WS-5 follow-up).
    match /appConfig/{docId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow write: if isBootstrapAdminEmail();
    }

    // ─── Deny everything else ──────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
